---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { withBase } from '../lib/url';
import { categories, projectsInCategory } from '../data/work';

// Applied research / selected projects — not a category with child pages,
// shown here as a closing section.
const research = [
  {
    title: 'Wind monitoring & structural dynamics',
    kicker: 'Signal processing',
    body:
      'Field instrumentation of a high-rise: Arduino sensing of wind excitation and tower acceleration, statistical analysis of ~660M data points, and bespoke apps deriving transfer functions and correlations in real time.',
  },
  {
    title: 'Free-form glass-panel optimization',
    kicker: 'Computational geometry',
    body:
      'A two-stage algorithm that first reduces the curvature of doubly-curved glass panels, then clusters them to minimise the number of moulds — cutting cost and wastage on free-form façades.',
  },
  {
    title: 'Steel connections by ML',
    kicker: 'AI · Optimization',
    body:
      'Machine-learning and optimization algorithms that suggest steel-joint connections with high accuracy, wrapped in an interactive design framework.',
  },
  {
    title: 'Reciprocal frame systems & gridshells',
    kicker: 'Research',
    body:
      'Homogenization studies of the elastic behaviour of reciprocal systems and computational architecture work, presented at IASS 2013 and Advances in Architectural Geometry 2014.',
  },
];
---

<BaseLayout
  title="Work — Raphos"
  description="Selected Raphos work, organised like the studio itself: Synera add-ins, Rhino/Grasshopper plugins (Dodo, Capybara), data-science web products (Babelotheca, CityDataLab, Ariadne's Gallery, Property Analytics London) and applied research."
  path="/work"
>
  <section class="section page-head-section">
    <div class="container container-wide">
      <p class="eyebrow">Selected work</p>
      <h1 class="page-title">Tools, products and research we’re proud of.</h1>
      <p class="lede page-lede">
        From plugins used by designers worldwide to data-science products and
        instrumented buildings — a sample of what we build and ship, grouped into
        three areas. Each project has its own page.
      </p>

      <nav class="cat-jump" aria-label="Work areas">
        {categories.map((c) => (
          <a href={withBase(`/work/${c.slug}`)}>
            <span class="cat-jump-eyebrow">{c.eyebrow}</span>
            <span class="cat-jump-name">{c.name} <span class="arrow">→</span></span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  {categories.map((category, i) => {
    const children = projectsInCategory(category.slug);
    return (
      <section class:list={['section', { 'section--alt': i % 2 === 0 }]}>
        <div class="container container-wide">
          <div class="cat-head">
            <div>
              <p class="eyebrow">{category.eyebrow}</p>
              <h2><a href={withBase(`/work/${category.slug}`)}>{category.name}</a></h2>
              <p class="cat-lede">{category.lede}</p>
            </div>
            <a class="cat-all" href={withBase(`/work/${category.slug}`)}>
              Overview <span class="arrow">→</span>
            </a>
          </div>
          <div class="grid grid--2 grid--3">
            {children.map((p) => (
              <ProjectCard
                title={p.title}
                kicker={p.kicker}
                href={withBase(`/work/${category.slug}/${p.slug}`)}
                tags={p.tags}
              >
                {p.summary}
              </ProjectCard>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <!-- R&D / selected projects -->
  <section class="section">
    <div class="container container-wide">
      <div class="section-head">
        <p class="eyebrow">R&amp;D</p>
        <h2>Applied research &amp; selected projects.</h2>
        <p>We do R&amp;D for real — published, instrumented and shipped.</p>
      </div>
      <div class="grid grid--2">
        {research.map((r) => (
          <ProjectCard title={r.title} kicker={r.kicker}>
            {r.body}
          </ProjectCard>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container container-wide cta-band">
      <div>
        <h2 class="cta-title">Want something like this built for you?</h2>
        <p class="cta-sub">We take on unconventional challenges others won’t.</p>
      </div>
      <a class="btn btn--primary" href="mailto:lorenzo@raphos.com">
        Get in touch <span class="arrow">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head-section { padding-bottom: var(--space-7); }
  .page-title { font-size: var(--fs-700); margin-top: var(--space-4); max-width: 18ch; }
  .page-lede { margin-top: var(--space-5); }

  .cat-jump {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-7);
  }
  @media (min-width: 48em) { .cat-jump { grid-template-columns: repeat(3, 1fr); } }
  .cat-jump a {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-ink);
  }
  .cat-jump a:hover { text-decoration: none; border-color: var(--color-accent); background: var(--color-accent-wash); }
  .cat-jump-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .cat-jump-name { font-weight: 600; font-size: var(--fs-300); }

  .cat-head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .cat-head h2 { font-size: var(--fs-600); margin-top: var(--space-3); }
  .cat-head h2 a { color: var(--color-ink); }
  .cat-head h2 a:hover { color: var(--color-accent); text-decoration: none; }
  .cat-lede { margin-top: var(--space-3); color: var(--color-ink-soft); max-width: 60ch; }
  .cat-all { font-size: var(--fs-200); font-weight: 540; white-space: nowrap; }

  .cta-band {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: var(--space-5); padding: var(--space-7); border-radius: var(--radius);
    border: 1px solid var(--color-line);
    background: radial-gradient(120% 140% at 100% 0%, var(--color-accent-wash), transparent 60%), var(--color-bg-alt);
  }
  .cta-title { font-size: var(--fs-500); }
  .cta-sub { color: var(--color-ink-soft); margin-top: var(--space-2); }
</style>
