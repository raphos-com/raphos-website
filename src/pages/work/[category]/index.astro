---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import ImagePlaceholder from '../../../components/ImagePlaceholder.astro';
import Figure from '../../../components/Figure.astro';
import { withBase } from '../../../lib/url';
import { categories, projectsInCategory } from '../../../data/work';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const children = projectsInCategory(category.slug);

const description = `${category.name} by Raphos — ${category.lede}`;
---

<BaseLayout
  title={`${category.name} — Raphos`}
  description={description}
  path={`/work/${category.slug}`}
>
  <section class="section page-head-section">
    <div class="container container-wide">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Work', href: '/work' },
          { label: category.name },
        ]}
      />
      <p class="eyebrow">{category.eyebrow}</p>
      <h1 class="page-title">{category.title}</h1>
      <p class="lede page-lede">{category.lede}</p>

      {category.links.length > 0 && (
        <ul class="ref-links" aria-label="Related links">
          {category.links.map((l) => (
            <li>
              <a href={l.href} rel="noopener" target="_blank">
                {l.label}<span class="ext" aria-hidden="true">↗</span>
              </a>
              {l.note && <span class="ref-note">{l.note}</span>}
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <section class="section--tight">
    <div class="container container-wide">
      {category.image.src ? (
        <Figure
          src={category.image.src}
          caption={category.image.caption}
          ratio={category.image.ratio}
          fit={category.image.fit}
          loading="eager"
          width="half"
        />
      ) : (
        <ImagePlaceholder caption={category.image.caption} ratio={category.image.ratio} />
      )}
    </div>
  </section>

  <section class="section">
    <div class="container container-wide">
      <div class="prose">
        {category.description.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container-wide">
      <div class="section-head">
        <p class="eyebrow">In this area</p>
        <h2>{children.length} {children.length === 1 ? 'project' : 'projects'}.</h2>
        <p>Open any project for the full write-up, capabilities and links.</p>
      </div>
      <div class="grid grid--2 grid--3">
        {children.map((p) => (
          <ProjectCard
            title={p.title}
            kicker={p.kicker}
            href={withBase(`/work/${category.slug}/${p.slug}`)}
            tags={p.tags}
          >
            {p.summary}
          </ProjectCard>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container container-wide cta-band">
      <div>
        <h2 class="cta-title">Want something like this for your team?</h2>
        <p class="cta-sub">We build computational tools and software for hard engineering problems.</p>
      </div>
      <a class="btn btn--primary" href="mailto:lorenzo@raphos.com">
        Get in touch <span class="arrow">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head-section { padding-bottom: var(--space-6); }
  .page-title { font-size: var(--fs-700); margin-top: var(--space-4); max-width: 18ch; }
  .page-lede { margin-top: var(--space-5); max-width: 56ch; }

  .ref-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
    margin-top: var(--space-6);
  }
  .ref-links li { display: inline-flex; align-items: baseline; gap: var(--space-2); }
  .ref-links a { font-weight: 540; font-size: var(--fs-200); }
  .ext { font-size: 0.7em; vertical-align: super; color: var(--color-muted); }
  .ref-note { font-size: var(--fs-100); color: var(--color-muted); }

  .prose { max-width: 64ch; }
  .prose p + p { margin-top: var(--space-4); }
  .prose p { color: var(--color-ink-soft); }

  .cta-band {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: var(--space-5); padding: var(--space-7); border-radius: var(--radius);
    border: 1px solid var(--color-line);
    background: radial-gradient(120% 140% at 100% 0%, var(--color-accent-wash), transparent 60%), var(--color-bg-alt);
  }
  .cta-title { font-size: var(--fs-500); }
  .cta-sub { color: var(--color-ink-soft); margin-top: var(--space-2); }
</style>
