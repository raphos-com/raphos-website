---
import BaseLayout from '../layouts/BaseLayout.astro';
import Figure from '../components/Figure.astro';

const backgrounds = [
  'Computer science',
  'Structural engineering',
  'Machine & deep learning',
  'Signal processing',
  'Cloud development',
  'Finance',
];

// Web3Forms access key (free — get one at https://web3forms.com). Public by
// design: it lives in client-side HTML. Submissions are emailed to the
// address the key is registered to.
const WEB3FORMS_ACCESS_KEY = '05120f6b-ab58-492e-a397-d899837d5b8c';
---

<BaseLayout
  title="Contact — Raphos"
  description="Get in touch with Raphos. We are engineers and scientists who tackle unconventional challenges with state-of-the-art algorithms and efficient software. Send us a message through the contact form."
  path="/contact"
>
  <section class="section contact-section">
    <div class="container container-wide contact-grid">
      <!-- left: pitch -->
      <div class="contact-intro stack">
        <p class="eyebrow">Contact</p>
        <h1 class="contact-title">Let’s build something that didn’t exist before.</h1>
        <p class="lede">
          We are engineers and scientists with a wide background. We love to push
          ourselves to tackle unconventional challenges — developing and
          implementing state-of-the-art algorithms and channelling them into
          efficient software.
        </p>

        <div class="bg-block">
          <p class="mono-label">We draw from</p>
          <ul class="bg-list">
            {backgrounds.map((b) => <li>{b}</li>)}
          </ul>
        </div>

        <div class="contact-img">
          <Figure
            src="/img/site/studio.jpeg"
            caption="The Raphos studio — Rhino, Grasshopper and a lot of code."
            ratio="16 / 9"
            fit="cover"
          />
        </div>
      </div>

      <!-- right: the actual contact card -->
      <aside class="contact-card">
        <p class="mono-label">Get in touch</p>
        <p class="contact-note">
          Tell us a little about the problem — the data you have, the constraints,
          and what a good outcome looks like. We read every message.
        </p>

        <form class="contact-form" id="contact-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
          <input type="hidden" name="subject" value="New enquiry via raphos.com" />
          <input type="hidden" name="from_name" value="Raphos website" />
          <!-- honeypot: bots fill this, humans never see it -->
          <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

          <label class="field">
            <span class="field-label">Name</span>
            <input class="field-input" type="text" name="name" autocomplete="name" required />
          </label>

          <label class="field">
            <span class="field-label">Email</span>
            <input class="field-input" type="email" name="email" autocomplete="email" placeholder="you@company.com" required />
          </label>

          <label class="field">
            <span class="field-label">Message</span>
            <textarea class="field-input" name="message" rows="5" required></textarea>
          </label>

          <button class="btn btn--primary contact-btn" type="submit">
            Send message <span class="arrow">→</span>
          </button>

          <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
        </form>

        <dl class="contact-meta">
          <div>
            <dt>Based in</dt>
            <dd>London, UK · working worldwide</dd>
          </div>
          <div>
            <dt>Elsewhere</dt>
            <dd>
              <a href="https://uk.linkedin.com/company/raphos" rel="noopener" target="_blank">
                LinkedIn ↗
              </a>
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; gap: var(--space-7); align-items: start; }
  @media (min-width: 54em) {
    .contact-grid { grid-template-columns: 1.3fr 1fr; gap: var(--space-9); }
  }
  .contact-title { font-size: var(--fs-700); }
  .contact-img { margin-top: var(--space-6); }

  .bg-block { margin-top: var(--space-5); }
  .bg-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  .bg-list li {
    font-size: var(--fs-200);
    color: var(--color-ink-soft);
    border: 1px solid var(--color-line);
    border-radius: 100px;
    padding: 0.35rem 0.85rem;
    background: var(--color-bg);
  }

  .contact-card {
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: var(--space-6);
    background:
      radial-gradient(140% 120% at 0% 0%, var(--color-accent-wash), transparent 55%),
      var(--color-bg-alt);
    position: sticky;
    top: 5.5rem;
  }
  .contact-note { margin-top: var(--space-4); color: var(--color-ink-soft); font-size: var(--fs-200); }
  .contact-btn { margin-top: var(--space-2); }

  /* form */
  .contact-form {
    margin-top: var(--space-5);
    display: grid;
    gap: var(--space-4);
  }
  .field { display: flex; flex-direction: column; gap: var(--space-2); }
  .field-label {
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .field-input {
    font-family: var(--font-sans);
    font-size: var(--fs-200);
    color: var(--color-ink);
    background: var(--color-bg);
    border: 1px solid var(--color-line-strong, var(--color-line));
    border-radius: var(--radius-sm, 6px);
    padding: 0.6rem 0.8rem;
    width: 100%;
    outline: none;
    transition: border-color var(--dur-fast, 150ms) var(--ease, ease),
      box-shadow var(--dur-fast, 150ms) var(--ease, ease);
  }
  textarea.field-input { resize: vertical; line-height: 1.5; }
  .field-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-wash);
  }
  /* honeypot — hidden from humans and assistive tech */
  .hp {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .form-status {
    font-size: var(--fs-200);
    line-height: 1.5;
    margin: 0;
    min-height: 1.2em;
  }
  .form-status[data-state='ok'] { color: var(--color-accent); }
  .form-status[data-state='error'] { color: var(--rf-coral, #e06848); }

  .contact-meta {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-line);
    display: grid;
    gap: var(--space-4);
  }
  .contact-meta dt { font-family: var(--font-mono); font-size: var(--fs-100); letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-muted); }
  .contact-meta dd { margin-top: var(--space-1); color: var(--color-ink-soft); font-size: var(--fs-200); }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  if (form && status) {
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      status.textContent = 'Sending…';
      status.removeAttribute('data-state');
      if (button) button.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await response.json().catch(() => ({}));

        if (response.ok && data.success) {
          form.reset();
          status.setAttribute('data-state', 'ok');
          status.textContent = 'Thanks — your message is on its way. We’ll be in touch soon.';
        } else {
          status.setAttribute('data-state', 'error');
          status.textContent =
            (data && data.message) ||
            'Something went wrong sending the form. Please try again in a moment.';
        }
      } catch {
        status.setAttribute('data-state', 'error');
        status.textContent =
          'Network error — please check your connection and try again.';
      } finally {
        if (button) button.disabled = false;
      }
    });
  }
</script>
