---
// A framed, captioned image. Mirrors ImagePlaceholder's frame so real images
// and (any remaining) placeholders sit together consistently. The src is a
// root-absolute path (e.g. "/img/work/foo.png") and is prefixed with the deploy
// base so it resolves under the GitHub Pages project subpath.
import { withBase } from '../lib/url';

export interface Props {
  /** Root-absolute path under /public, e.g. "/img/work/foo.png". */
  src: string;
  /** Visible caption — also used as the image's alt text. */
  caption?: string;
  /** CSS aspect-ratio for the frame, e.g. "16 / 9", "4 / 3". */
  ratio?: string;
  /** How the image fills the frame. Screenshots/photos: cover; logos/diagrams: contain. */
  fit?: 'cover' | 'contain';
  /** Set "eager" for above-the-fold heroes; everything else lazy-loads. */
  loading?: 'lazy' | 'eager';
  /** "half" caps the figure at ~50% width (centred) on larger screens. */
  width?: 'full' | 'half';
}

const { src, caption, ratio = '16 / 9', fit = 'cover', loading = 'lazy', width = 'full' } = Astro.props;
---

<figure class:list={['fig', { 'fig--half': width === 'half' }]}>
  <div class="fig-frame" style={`aspect-ratio: ${ratio};`}>
    <img
      src={withBase(src)}
      alt={caption ?? ''}
      loading={loading}
      decoding="async"
      class:list={['fig-img', `fit-${fit}`]}
    />
  </div>
  {caption && <figcaption class="fig-cap">{caption}</figcaption>}
</figure>

<style>
  .fig { margin: 0; }
  @media (min-width: 48em) {
    .fig--half { max-width: 50%; margin-inline: auto; }
  }
  .fig-frame {
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-bg-alt);
  }
  .fig-img { width: 100%; height: 100%; display: block; }
  .fit-cover { object-fit: cover; object-position: center top; }
  .fit-contain { object-fit: contain; padding: var(--space-4); }
  .fig-cap {
    margin-top: var(--space-2);
    font-size: var(--fs-100);
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>
