---
import { withBase } from '../lib/url';
import { categories, projectsInCategory } from '../data/work';

export interface Props {
  path?: string;
}
const { path = '/' } = Astro.props;

// Build the Work submenu from the same data the pages use, so the nav
// always stays in sync with the actual categories and projects.
const workMenu = categories.map((c) => ({
  slug: c.slug,
  name: c.name,
  children: projectsInCategory(c.slug).map((p) => ({
    slug: p.slug,
    title: p.title,
  })),
}));

const links = [
  { href: '/', label: 'Home' },
  { href: '/capabilities', label: 'Capabilities' },
  { href: '/work', label: 'Work', submenu: true },
  { href: '/contact', label: 'Contact' },
];

const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header">
  <div class="container container-wide header-inner">
    <a class="brand" href={withBase('/')} aria-label="Raphos — home">
      <svg class="brand-mark" viewBox="0 0 32 32" width="26" height="26" aria-hidden="true">
        <g stroke="var(--color-accent)" stroke-width="1.7" fill="none" stroke-linecap="round">
          <path d="M8 22 L8 10 L18 10 Q23 10 23 14.5 Q23 19 18 19 L8 19" />
          <path d="M16 19 L23 24" />
        </g>
        <g fill="var(--color-accent)">
          <circle cx="8" cy="10" r="2"/>
          <circle cx="18" cy="10" r="2"/>
          <circle cx="8" cy="22" r="2"/>
          <circle cx="23" cy="24" r="2"/>
          <circle cx="22.5" cy="14.5" r="2"/>
        </g>
      </svg>
      <span class="brand-word">Raphos</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
      <label for="nav-toggle" class="nav-burger" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </label>
      <ul class="nav-list">
        {links.map((l) => (
          l.submenu ? (
            <li class="nav-item has-mega">
              <a
                href={withBase(l.href)}
                class:list={['nav-link', 'nav-link--parent', { 'is-active': isActive(l.href) }]}
                aria-current={isActive(l.href) ? 'page' : undefined}
              >
                {l.label}
                <svg class="caret" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>

              <div class="mega" role="group" aria-label="Work">
                {workMenu.map((cat) => (
                  <div class="mega-col">
                    <a class="mega-cat" href={withBase(`/work/${cat.slug}`)}>{cat.name}</a>
                    <ul class="mega-links">
                      {cat.children.map((child) => (
                        <li>
                          <a href={withBase(`/work/${cat.slug}/${child.slug}`)}>{child.title}</a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </li>
          ) : (
            <li class="nav-item">
              <a
                href={withBase(l.href)}
                class:list={['nav-link', { 'is-active': isActive(l.href) }]}
                aria-current={isActive(l.href) ? 'page' : undefined}
              >
                {l.label}
              </a>
            </li>
          )
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-ink);
    font-weight: 680;
    letter-spacing: -0.02em;
    font-size: 1.2rem;
  }
  .brand:hover { text-decoration: none; }
  .brand-word { line-height: 1; }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .nav-item { position: relative; }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.45rem 0.8rem;
    color: var(--color-ink-soft);
    font-size: var(--fs-200);
    font-weight: 520;
    border-radius: var(--radius-sm);
  }
  .nav-link:hover { color: var(--color-ink); background: var(--color-accent-wash); text-decoration: none; }
  .nav-link.is-active { color: var(--color-ink); }
  .nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 0.8rem;
    right: 0.8rem;
    bottom: 0.15rem;
    height: 2px;
    border-radius: 2px;
    background: var(--color-accent);
  }
  .caret { transition: transform 0.2s var(--ease); opacity: 0.7; }

  /* ---------- mega-menu (desktop) ---------- */
  .mega {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(11rem, 1fr));
    gap: var(--space-5);
    width: max-content;
    max-width: min(46rem, calc(100vw - 2rem));
    padding: var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    box-shadow: 0 24px 60px -30px rgba(20, 22, 26, 0.45);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.18s var(--ease), transform 0.18s var(--ease), visibility 0.18s;
  }
  /* bridge the gap so the menu doesn't close when the cursor crosses it */
  .has-mega::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 0.6rem;
  }
  .has-mega:hover .mega,
  .has-mega:focus-within .mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .has-mega:hover .caret,
  .has-mega:focus-within .caret { transform: rotate(180deg); }

  .mega-cat {
    display: block;
    font-weight: 620;
    font-size: var(--fs-200);
    color: var(--color-ink);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-line);
  }
  .mega-cat:hover { color: var(--color-accent); text-decoration: none; }
  .mega-links { margin-top: var(--space-3); display: grid; gap: var(--space-1); }
  .mega-links a {
    display: block;
    padding: 0.3rem 0;
    color: var(--color-ink-soft);
    font-size: var(--fs-200);
  }
  .mega-links a:hover { color: var(--color-accent); text-decoration: none; }

  /* ---------- mobile menu mechanics (CSS-only, no JS) ---------- */
  .nav-toggle, .nav-burger { display: none; }

  @media (max-width: 46em) {
    .nav-burger {
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 2.5rem;
      height: 2.5rem;
      padding: 0 0.55rem;
      border: 1px solid var(--color-line-strong);
      border-radius: var(--radius-sm);
      cursor: pointer;
    }
    .nav-burger span {
      height: 2px;
      background: var(--color-ink);
      border-radius: 2px;
      transition: transform 0.2s var(--ease), opacity 0.2s var(--ease);
    }
    .nav-list {
      position: absolute;
      top: 4.25rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-line);
      padding: var(--space-3) var(--space-5) var(--space-5);
      max-height: calc(100vh - 4.25rem);
      overflow-y: auto;
      transform: translateY(-12px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s var(--ease), transform 0.2s var(--ease);
    }
    .nav-link { padding: 0.7rem 0; font-size: var(--fs-300); }
    .nav-link.is-active::after { display: none; }
    .nav-link--parent .caret { display: none; }
    .nav-toggle:checked ~ .nav-list {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* On mobile the submenu is shown inline (expanded), not as a popover. */
    .has-mega::after { display: none; }
    .mega {
      position: static;
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
      width: auto;
      max-width: none;
      padding: 0 0 var(--space-3) var(--space-4);
      border: 0;
      border-left: 2px solid var(--color-line);
      border-radius: 0;
      box-shadow: none;
      opacity: 1;
      visibility: visible;
      transform: none;
    }
    .mega-links a { padding: 0.4rem 0; }
  }
</style>
