---
import { withBase } from '../lib/url';
import { categories, projectsInCategory } from '../data/work';

export interface Props {
  path?: string;
}
const { path = '/' } = Astro.props;

// Build the Work submenu from the same data the pages use, so the nav
// always stays in sync with the actual categories and projects.
const workMenu = categories.map((c) => ({
  slug: c.slug,
  name: c.name,
  children: projectsInCategory(c.slug).map((p) => ({
    slug: p.slug,
    title: p.title,
  })),
}));

const links = [
  { href: '/', label: 'Home' },
  { href: '/capabilities', label: 'Capabilities' },
  { href: '/work', label: 'Work', submenu: true },
  { href: '/contact', label: 'Contact' },
];

const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header">
  <div class="container container-wide header-inner">
    <a class="brand" href={withBase('/')} aria-label="Raphos — home">
      <svg class="brand-mark" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
        <path
          fill="var(--color-accent)"
          d="m 11.020432,19.067292 c 0.923785,-0.281408 1.848877,-0.563215 2.951918,-1.092504 1.103041,-0.52929 2.386049,-1.306497 3.395019,-2.1058 1.008969,-0.799304 1.744563,-1.621179 2.206318,-2.326331 0.461755,-0.705152 0.649929,-1.294758 0.61276,-1.718736 -0.03717,-0.423978 -0.302323,-0.683046 -0.866695,-1.080883 -0.564372,-0.397837 -1.428263,-0.933841 -1.831657,-1.4875262 -0.403394,-0.5536853 -0.34352,-1.1254251 0.02069,-1.5331086 0.364216,-0.4076836 1.031381,-0.648886 1.561757,-0.6346698 0.530377,0.014216 0.920141,0.2800491 1.312389,0.5475763 0.381234,0.1575452 0.765055,0.3161591 1.082929,0.2331322 C 21.78374,7.785415 22.041334,7.4622666 22.298681,7.1394273 21.165208,6.0544984 20.033976,4.9717141 19.402266,4.1525225 18.770556,3.3333308 18.642255,2.779459 18.305388,2.3767477 17.968521,1.9740364 17.421106,1.7239012 16.697875,1.6740268 c -0.72323,-0.049874 -1.621335,0.1019935 -2.272486,0.5402821 -0.651151,0.4382886 -1.05316,1.1618958 -1.189586,1.8997827 -0.136426,0.7378869 -0.0081,1.4882941 0.150399,2.1137213 0.158525,0.6254272 0.3467,1.1256984 -0.09337,1.4324892 C 12.852757,7.9670929 11.783582,8.0832275 10.911462,8.0346027 10.039341,7.9859779 9.3636237,7.7715759 8.9733962,7.4061587 8.5831688,7.0407414 8.4805282,6.5226035 8.6812297,5.9943035 8.8819312,5.4660035 9.3865813,4.9299983 9.4343484,4.7242602 9.4821156,4.5185222 9.0702188,4.6439965 8.6596477,4.7690669 7.7187557,5.0013405 6.7793501,5.2332471 5.7779164,5.7872505 4.7764827,6.341254 3.715862,7.2167291 3.0826483,8.2227305 2.4494345,9.228732 2.2441531,10.363276 2.2059675,11.47585 c -0.038186,1.112573 0.090115,2.20245 0.4714965,3.189641 0.3813813,0.98719 1.0143326,1.871599 1.7631876,2.527629 0.748855,0.65603 1.6101592,1.083549 2.4740692,1.512361 0,0 0.4362314,2.586278 0.4362314,2.586278 0,0 2.181159,1.112231 2.181159,1.112231 0,0 3.9600688,-0.0483 3.9600688,-0.0483 -0.601524,-0.510981 -1.20051,-1.019806 -1.613237,-1.567634 -0.412726,-0.547828 -0.636119,-1.135612 -0.858511,-1.720763 z"
        />
      </svg>
      <span class="brand-word">Raphos</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
      <label for="nav-toggle" class="nav-burger" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </label>
      <ul class="nav-list">
        {links.map((l) => (
          l.submenu ? (
            <li class="nav-item has-mega">
              <a
                href={withBase(l.href)}
                class:list={['nav-link', 'nav-link--parent', { 'is-active': isActive(l.href) }]}
                aria-current={isActive(l.href) ? 'page' : undefined}
              >
                {l.label}
                <svg class="caret" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>

              <div class="mega" role="group" aria-label="Work">
                {workMenu.map((cat) => (
                  <div class="mega-col">
                    <a class="mega-cat" href={withBase(`/work/${cat.slug}`)}>{cat.name}</a>
                    <ul class="mega-links">
                      {cat.children.map((child) => (
                        <li>
                          <a href={withBase(`/work/${cat.slug}/${child.slug}`)}>{child.title}</a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </li>
          ) : (
            <li class="nav-item">
              <a
                href={withBase(l.href)}
                class:list={['nav-link', { 'is-active': isActive(l.href) }]}
                aria-current={isActive(l.href) ? 'page' : undefined}
              >
                {l.label}
              </a>
            </li>
          )
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-ink);
    font-weight: 680;
    letter-spacing: -0.02em;
    font-size: 1.2rem;
  }
  .brand:hover { text-decoration: none; }
  .brand-word { line-height: 1; }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .nav-item { position: relative; }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.45rem 0.8rem;
    color: var(--color-ink-soft);
    font-size: var(--fs-200);
    font-weight: 520;
    border-radius: var(--radius-sm);
  }
  .nav-link:hover { color: var(--color-ink); background: var(--color-accent-wash); text-decoration: none; }
  .nav-link.is-active { color: var(--color-ink); }
  .nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 0.8rem;
    right: 0.8rem;
    bottom: 0.15rem;
    height: 2px;
    border-radius: 2px;
    background: var(--color-accent);
  }
  .caret { transition: transform 0.2s var(--ease); opacity: 0.7; }

  /* ---------- mega-menu (desktop) ---------- */
  .mega {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(11rem, 1fr));
    gap: var(--space-5);
    width: max-content;
    max-width: min(46rem, calc(100vw - 2rem));
    padding: var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    box-shadow: 0 24px 60px -30px rgba(20, 22, 26, 0.45);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.18s var(--ease), transform 0.18s var(--ease), visibility 0.18s;
  }
  /* bridge the gap so the menu doesn't close when the cursor crosses it */
  .has-mega::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 0.6rem;
  }
  .has-mega:hover .mega,
  .has-mega:focus-within .mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .has-mega:hover .caret,
  .has-mega:focus-within .caret { transform: rotate(180deg); }

  .mega-cat {
    display: block;
    font-weight: 620;
    font-size: var(--fs-200);
    color: var(--color-ink);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-line);
  }
  .mega-cat:hover { color: var(--color-accent); text-decoration: none; }
  .mega-links { margin-top: var(--space-3); display: grid; gap: var(--space-1); }
  .mega-links a {
    display: block;
    padding: 0.3rem 0;
    color: var(--color-ink-soft);
    font-size: var(--fs-200);
  }
  .mega-links a:hover { color: var(--color-accent); text-decoration: none; }

  /* ---------- mobile menu mechanics (CSS-only, no JS) ---------- */
  .nav-toggle, .nav-burger { display: none; }

  @media (max-width: 46em) {
    .nav-burger {
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 2.5rem;
      height: 2.5rem;
      padding: 0 0.55rem;
      border: 1px solid var(--color-line-strong);
      border-radius: var(--radius-sm);
      cursor: pointer;
    }
    .nav-burger span {
      height: 2px;
      background: var(--color-ink);
      border-radius: 2px;
      transition: transform 0.2s var(--ease), opacity 0.2s var(--ease);
    }
    .nav-list {
      position: absolute;
      top: 4.25rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-line);
      padding: var(--space-3) var(--space-5) var(--space-5);
      max-height: calc(100vh - 4.25rem);
      overflow-y: auto;
      transform: translateY(-12px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s var(--ease), transform 0.2s var(--ease);
    }
    .nav-link { padding: 0.7rem 0; font-size: var(--fs-300); }
    .nav-link.is-active::after { display: none; }
    .nav-link--parent .caret { display: none; }
    .nav-toggle:checked ~ .nav-list {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* On mobile the submenu is shown inline (expanded), not as a popover. */
    .has-mega::after { display: none; }
    .mega {
      position: static;
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
      width: auto;
      max-width: none;
      padding: 0 0 var(--space-3) var(--space-4);
      border: 0;
      border-left: 2px solid var(--color-line);
      border-radius: 0;
      box-shadow: none;
      opacity: 1;
      visibility: visible;
      transform: none;
    }
    .mega-links a { padding: 0.4rem 0; }
  }
</style>
