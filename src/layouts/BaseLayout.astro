---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../lib/url';

export interface Props {
  title?: string;
  description?: string;
  /** Path of the current page, used for canonical + nav active state, e.g. "/work" */
  path?: string;
}

const {
  title = 'Raphos — Engineering, ML & Data Science',
  description =
    'Raphos is a London consultancy at the intersection of engineering, machine learning and data science. We build computational tools, models and software for hard engineering problems.',
  path = '/',
} = Astro.props;

const origin = Astro.site ?? new URL('https://raphos-com.github.io');
const site = new URL(withBase('/'), origin).toString().replace(/\/$/, '');
const canonical = new URL(withBase(path), origin).toString();
const ogImage = new URL(withBase('/og.svg'), origin).toString();
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="theme-color" content="#0f1115" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Raphos" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Organization structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Raphos',
        url: site,
        description,
        foundingDate: '2018',
        areaServed: 'Worldwide',
        knowsAbout: [
          'Finite Element Analysis',
          'Machine Learning',
          'Data Science',
          'Signal Processing',
          'Computational Geometry',
          'Numerical Optimization',
        ],
        email: 'lorenzo@raphos.com',
        sameAs: [
          'https://uk.linkedin.com/company/raphos',
          'https://www.researchgate.net/profile/Lorenzo-Greco',
        ],
      })}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header path={path} />
    <main id="main">
      <slot />
    </main>
    <Footer year={year} />
  </body>
</html>
